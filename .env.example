APP_NAME="Enterprise AX Agent Platform"
APP_ENV=local
LOG_LEVEL=INFO

# Optional. If empty, the MVP uses deterministic local answer synthesis.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Local-first defaults.
RUNTIME_DIR=data/runtime
SAMPLE_DOCS_DIR=data/sample_docs
EMBEDDING_DIMENSIONS=384
TOP_K=4

# memory/local keeps the project runnable without external services.
# postgres/qdrant switches the same ports to production-like adapters.
STORAGE_BACKEND=memory
VECTOR_BACKEND=local

# Future remote vector DB mode.
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=ax_agent_chunks

# Postgres mode.
POSTGRES_DSN=postgresql://ax_agent:ax_agent@localhost:5432/ax_agent
