APP_NAME=Enterprise AX Agent Platform
APP_ENV=local
LOG_LEVEL=INFO

STORAGE_BACKEND=postgres
VECTOR_BACKEND=qdrant
RUNTIME_DIR=data/runtime
SAMPLE_DOCS_DIR=data/sample_docs
EMBEDDING_DIMENSIONS=384
TOP_K=4
MONTHLY_AGENT_RUN_QUOTA=1000

AUTH_ENABLED=false
API_KEY_CREDENTIALS=

POSTGRES_DSN=postgresql://ax_agent_app:ax_agent_app@localhost:5432/ax_agent
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=ax_agent_chunks
CONTAINER_POSTGRES_DSN=postgresql://ax_agent_app:ax_agent_app@postgres:5432/ax_agent
CONTAINER_QDRANT_URL=http://qdrant:6333

WEBHOOK_TIMEOUT_SECONDS=3
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_LEASE_SECONDS=60
WEBHOOK_WORKER_TENANT_ID=default
WEBHOOK_WORKER_LIMIT=100
WEBHOOK_WORKER_INTERVAL_SECONDS=15

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
